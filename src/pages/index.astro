---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="DevClub Portal">
  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center space-y-6">
    <h1 class="text-5xl font-bold bg-gradient-to-r from-[var(--md-sys-color-primary)] to-purple-400 bg-clip-text text-transparent">
      DevClub Portal
    </h1>
    <p class="text-xl max-w-2xl text-[var(--md-sys-color-on-background)] opacity-80">
      Central hub for all DevClub documentation, resources, and community guidelines.
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8 w-full max-w-2xl">
      <a href="/contributors/wiki" class="group p-6 rounded-2xl bg-[var(--md-sys-color-surface-variant)] hover:ring-2 hover:ring-[var(--md-sys-color-primary)] transition-all">
        <h2 class="text-2xl font-semibold mb-2 text-[var(--md-sys-color-primary)]">Contributors</h2>
        <p class="text-sm">Access the contributors wiki regarding project setup, guidelines, and more.</p>
      </a>
      
       <a href="/cloud-data-ai/wiki" class="group p-6 rounded-2xl bg-[var(--md-sys-color-surface-variant)] hover:ring-2 hover:ring-[var(--md-sys-color-primary)] transition-all">
        <h2 class="text-2xl font-semibold mb-2 text-[var(--md-sys-color-primary)]">Cloud Data AI</h2>
        <p class="text-sm">Resources and documentation for the Cloud Data AI special interest group.</p>
      </a>
    </div>
  </div>
</MainLayout>
