---
import GDGLayout from "../layouts/GDGLayout.astro";
import { EVENTS, getEventCardParts } from "../data/events";

const featuredEvents = EVENTS.slice(0, 2).map((event) => ({
  ...event,
  parts: getEventCardParts(event),
}));
---

<GDGLayout
  title="GDG Querétaro — Google Developer Group"
  description="Comunidad de desarrolladores de Google en Querétaro. Eventos, talleres, networking y crecimiento profesional con tecnologías Google."
>
  <!-- ═══════════════════════════════════════════════════
       HERO SECTION
       ═══════════════════════════════════════════════════ -->
  <section class="hero container" id="inicio">
    <!-- Top row: Logo + "Google Developer Group" title -->
    <div class="hero__top">
      <div class="hero__logo-area" data-animate>
        <!-- GDG Brackets logo (inline SVG from assets) -->
        <svg
          width="128"
          height="77"
          viewBox="0 0 128 77"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-label="GDG Logo"
        >
          <path
            d="M38.2457 9.17317L11.9771 28.0491C6.46191 32.0122 5.20365 39.6958 9.1667 45.2109C13.1298 50.7261 20.8134 51.9843 26.3285 48.0213L52.5972 29.1454C58.1124 25.1823 59.3706 17.4987 55.4076 11.9835C51.4445 6.46835 43.7609 5.21012 38.2457 9.17317Z"
            fill="#EA4335"></path>
          <path
            d="M54.2773 12.7955C50.7627 7.90451 43.9485 6.78902 39.0575 10.3036L12.7889 29.1795C7.89795 32.6941 6.78215 39.5078 10.2966 44.3988C13.8111 49.2898 20.6253 50.406 25.5163 46.8916L51.7849 28.0156C56.6759 24.5011 57.7919 17.6865 54.2773 12.7955ZM56.5372 11.1715C60.9488 17.3108 59.5481 25.864 53.4088 30.2756L27.1402 49.1515C21.0009 53.5629 12.4477 52.1624 8.03616 46.0231C3.62472 39.8838 5.02539 31.3306 11.1646 26.919L37.4332 8.04312C43.5725 3.6316 52.1257 5.03229 56.5372 11.1715Z"
            fill="#1E1E1E"></path>
          <path
            d="M26.2799 27.999C20.7648 24.0359 13.0812 25.2941 9.11813 30.8093C5.15508 36.3245 6.41331 44.0081 11.9285 47.9711L38.1971 66.8471C43.7123 70.8101 51.3959 69.5519 55.359 64.0367C59.322 58.5215 58.0638 50.838 52.5486 46.8749L26.2799 27.999Z"
            fill="#4285F4"></path>
          <path
            d="M25.4679 29.1288C20.5769 25.6143 13.7628 26.7306 10.2483 31.6216C6.73382 36.5126 7.84961 43.3263 12.7405 46.8409L39.0091 65.7168C43.9001 69.2313 50.7144 68.1159 54.229 63.2249C57.7435 58.3339 56.6276 51.5193 51.7366 48.0047L25.4679 29.1288ZM53.3605 45.7448C59.4998 50.1563 60.9004 58.7095 56.4889 64.8489C52.0774 70.9881 43.5241 72.3888 37.3849 67.9773L11.1162 49.1013C4.97703 44.6898 3.5764 36.1366 7.98782 29.9973C12.3993 23.858 20.9526 22.4574 27.0919 26.8689L53.3605 45.7448Z"
            fill="#1E1E1E"></path>
          <path
            d="M101.721 28.0579L75.4519 46.9339C69.9368 50.8969 68.6785 58.5805 72.6416 64.0957C76.6046 69.6109 84.2882 70.8691 89.8034 66.9061L116.072 48.0301C121.587 44.0671 122.845 36.3834 118.882 30.8683C114.919 25.3531 107.236 24.0949 101.721 28.0579Z"
            fill="#F9AB00"></path>
          <path
            d="M117.752 31.6802C114.238 26.7893 107.423 25.6738 102.532 29.1883L76.2637 48.0643C71.3728 51.5788 70.257 58.3926 73.7715 63.2836C77.286 68.1746 84.1001 69.2908 88.9911 65.7763L115.26 46.9004C120.151 43.3858 121.267 36.5713 117.752 31.6802ZM120.012 30.0563C124.424 36.1956 123.023 44.7488 116.884 49.1603L90.6151 68.0363C84.4758 72.4477 75.9225 71.0471 71.511 64.9079C67.0996 58.7686 68.5002 50.2153 74.6394 45.8038L100.908 26.9279C107.047 22.5164 115.601 23.9171 120.012 30.0563Z"
            fill="#1E1E1E"></path>
          <path
            d="M89.7472 9.11799C84.2321 5.15494 76.5485 6.41315 72.5854 11.9283C68.6224 17.4435 69.8806 25.1271 75.3958 29.0902L101.664 47.9661C107.18 51.9292 114.863 50.6709 118.826 45.1557C122.789 39.6406 121.531 31.957 116.016 27.9939L89.7472 9.11799Z"
            fill="#34A853"></path>
          <path
            d="M88.9352 10.2477C84.0442 6.73323 77.2301 7.84949 73.7156 12.7405C70.2011 17.6315 71.3169 24.4452 76.2078 27.9598L102.476 46.8357C107.367 50.3502 114.182 49.2348 117.696 44.3438C121.211 39.4528 120.095 32.6382 115.204 29.1236L88.9352 10.2477ZM116.828 26.8637C122.967 31.2752 124.368 39.8284 119.956 45.9678C115.545 52.107 106.991 53.5077 100.852 49.0962L74.5835 30.2202C68.4443 25.8087 67.0437 17.2555 71.4551 11.1162C75.8666 4.97691 84.4199 3.57632 90.5592 7.98778L116.828 26.8637Z"
            fill="#1E1E1E"></path>
        </svg>
      </div>
      <div class="hero__title-area" data-animate>
        <!-- "Google Developer Group" branded text SVG -->
        <img
          src="/assets/Google-Developer-Group__title-font-branded.svg"
          alt="Google Developer Group"
          width="1023"
          height="92"
          loading="eager"
        />
      </div>
    </div>

    <!-- Body: Text left + Categories right -->
    <div class="hero__body">
      <div class="hero__text" data-animate>
        <h1>¡Aprende<br />en comunidad!</h1>
        <p>
          Conecta, aprende y crece junto a talento local. Asiste a sesiones,
          talleres y networkings sobre Open Source y tecnologías Google.
        </p>
        <div>
          <a
            href="https://gdg.community.dev/gdg-queretaro/"
            class="btn-primary"
            target="_blank"
            rel="noopener"
            style="font-size: var(--fs-body); padding: 0.75rem 2rem;"
          >
            Asistir
          </a>
          <a
            href="/contributors"
            class="btn-outline"
            style="margin-left: 1rem; font-size: var(--fs-body); padding: 0.75rem 2rem;"
          >
            Wiki
          </a>
        </div>
      </div>

      <!-- Categories -->
      <div class="categories" id="clubs">
        <a
          href="/cloud-ai/"
          class="category-card category-card--blue animate-in"
          data-animate
        >
          <div class="category-card__icon">
            <!-- Cloud icon -->
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path
                d="M19.35 10.04A7.49 7.49 0 0012 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 000 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM19 18H6c-2.21 0-4-1.79-4-4s1.79-4 4-4h.71C7.37 7.69 9.48 6 12 6a5.5 5.5 0 015.35 4.16l.34 1.34H19c1.65 0 3 1.35 3 3s-1.35 3-3 3z"
              ></path></svg
            >
          </div>
          <span class="category-card__label">AI &<br />Cloud</span>
        </a>

        <a
          href="/empowerment/"
          class="category-card category-card--red animate-in"
          data-animate
        >
          <div class="category-card__icon">
            <!-- Tux / Linux icon -->
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path
                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
              ></path></svg
            >
          </div>
          <span class="category-card__label">Mujeres x<br />Diversidad</span>
        </a>

        <a
          href="/computer-science/"
          class="category-card category-card--yellow animate-in"
          data-animate
        >
          <div class="category-card__icon">
            <!-- Terminal / CS icon -->
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path
                d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8h16v10zm-2-1h-6v-2h6v2zM7.5 17l-1.41-1.41L8.67 13l-2.59-2.59L7.5 9l4 4-4 4z"
              ></path></svg
            >
          </div>
          <span class="category-card__label">Computer<br />Science</span>
        </a>

        <a
          href="/design-code/"
          class="category-card category-card--green animate-in"
          data-animate
        >
          <div class="category-card__icon">
            <!-- Code icon -->
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path
                d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"
              ></path></svg
            >
          </div>
          <span class="category-card__label">Código<br />y Diseño</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       PRÓXIMOS EVENTOS
       ═══════════════════════════════════════════════════ -->
  <section class="section section--compact container" id="eventos">
    <div
      style="display:flex; justify-content:space-between; gap:1rem; align-items:end; flex-wrap:wrap;"
    >
      <h2 class="section__heading" data-animate>Próximos Eventos</h2>
      <a href="/events/" class="btn-outline" style="padding: 0.65rem 1.5rem;">
        Ver calendario
      </a>
    </div>
    <div class="events-grid">
      {
        featuredEvents.map((event) => (
          <a href={event.href} class="event-card" data-animate>
            <div class="event-card__image">
              <div
                class="event-card__image-placeholder"
                style={`background:
                  linear-gradient(135deg, ${event.club === "cloud-ai" ? "#4285F4" : event.club === "empowerment" ? "#EA4335" : "#34A853"} 0%, rgba(15,17,21,0.92) 85%);
                  align-items:flex-end; justify-content:flex-start; padding:1rem;`}
              >
                <span
                  class="font-code"
                  style="font-size:0.78rem; letter-spacing:0.08em; text-transform:uppercase;"
                >
                  {event.bannerLabel ?? "Evento"}
                </span>
              </div>
            </div>
            <div class="event-card__body">
              <div class="event-card__date">
                <span class="event-card__date-weekday font-code">{event.parts.weekday}</span>
                <span class="event-card__date-day">{event.parts.day}</span>
                <span class="event-card__date-month font-code">{event.parts.month}</span>
              </div>
              <div class="event-card__info">
                <h3>{event.title}</h3>
                <div class="event-card__meta font-code">
                  <span>{event.parts.time}</span>
                  <span>{event.venue}</span>
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       CONTRIBUYE Y LIDERA
       ═══════════════════════════════════════════════════ -->
  <section class="section section--compact container" id="contribuye">
    <h2 class="section__heading" data-animate>Contribuye y lidera</h2>

    <div class="contributors-grid">
      <div class="contributor-card" data-animate>
        <div class="contributor-card__icon" aria-hidden="true">
          <span class="material-symbols-rounded">school</span>
        </div>
        <div class="contributor-card__title">Mentores</div>
        <div class="contributor-card__avatars">
          <div class="contributor-card__avatar">
            <span class="avatar-wrapper" data-handle="🐙 javarv87">
              <a href="https://github.com/javarv87" target="_blank" rel="noopener">
                <img
                  src="https://github.com/javarv87.png"
                  alt="javarv87"
                  loading="lazy"
                  width="56"
                  height="56"
                />
              </a>
            </span>
          </div>
          <div class="contributor-card__avatar">
            <span class="avatar-wrapper" data-handle="🐙 renecloud">
              <a href="https://github.com/renecloud" target="_blank" rel="noopener">
                <img
                  src="https://github.com/renecloud.png"
                  alt="renecloud"
                  loading="lazy"
                  width="56"
                  height="56"
                />
              </a>
            </span>
          </div>
        </div>
      </div>

      <div class="contributor-card" data-animate>
        <div class="contributor-card__icon" aria-hidden="true">
          <span class="material-symbols-rounded">groups</span>
        </div>
        <div class="contributor-card__title">Club<br />Organizers</div>
        <div class="contributor-card__avatars">
          <div class="contributor-card__avatar">
            <span class="avatar-wrapper" data-handle="🐙 yoshi-ortiz">
              <a href="https://github.com/yoshi-ortiz" target="_blank" rel="noopener">
                <img
                  src="https://github.com/yoshi-ortiz.png"
                  alt="yoshi-ortiz"
                  loading="lazy"
                  width="56"
                  height="56"
                />
              </a>
            </span>
          </div>
          <div class="contributor-card__avatar">
            <span class="avatar-wrapper" data-handle="🐙 xbreton">
              <a href="https://github.com/xbreton" target="_blank" rel="noopener">
                <img
                  src="https://github.com/xbreton.png"
                  alt="xbreton"
                  loading="lazy"
                  width="56"
                  height="56"
                />
              </a>
            </span>
          </div>
          <div class="contributor-card__avatar">
            <span class="avatar-wrapper" data-handle="🔗 cvjj">
              <a href="https://www.linkedin.com/in/cvjj" target="_blank" rel="noopener">
                <img
                  src="https://cdn.jsdelivr.net/gh/simple-icons/simple-icons/icons/linkedin.svg"
                  alt="LinkedIn profile"
                  width="56"
                  height="56"
                  loading="lazy"
                  style="background:#fff; border-radius:50%; padding:6px;"
                />
              </a>
            </span>
          </div>
        </div>
      </div>

      <div class="contributor-card" data-animate>
        <div class="contributor-card__icon" aria-hidden="true">
          <span class="material-symbols-rounded">volunteer_activism</span>
        </div>
        <div class="contributor-card__title">
          Productores<br />y voluntarios
        </div>
        <div class="contributor-card__avatars">
          <div class="contributor-card__avatar">
            <span class="avatar-wrapper" data-handle="🔗 dsgn-becerra">
              <a href="https://www.linkedin.com/in/dsgn-becerra" target="_blank" rel="noopener">
                <img
                  src="https://cdn.jsdelivr.net/gh/simple-icons/simple-icons/icons/linkedin.svg"
                  alt="LinkedIn profile"
                  width="56"
                  height="56"
                  loading="lazy"
                  style="background:#fff; border-radius:50%; padding:6px;"
                />
              </a>
            </span>
          </div>
          <div class="contributor-card__avatar">
            <span class="avatar-wrapper" data-handle="🔗 eduardo-mac-909341a3">
              <a href="https://www.linkedin.com/in/eduardo-mac-909341a3" target="_blank" rel="noopener">
                <img
                  src="https://cdn.jsdelivr.net/gh/simple-icons/simple-icons/icons/linkedin.svg"
                  alt="LinkedIn profile"
                  width="56"
                  height="56"
                  loading="lazy"
                  style="background:#fff; border-radius:50%; padding:6px;"
                />
              </a>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       SPONSOR CTA
       ═══════════════════════════════════════════════════ -->
  <section class="sponsor-cta container" id="unete" data-animate>
    <a href="mailto:gdgqueretaro@googlegroups.com">
      Participa como patrocinador →
    </a>
  </section>
</GDGLayout>
