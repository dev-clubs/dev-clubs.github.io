---
import GDGLayout from "../../layouts/GDGLayout.astro";
---

<GDGLayout
    title="Código y Diseño — GDG Querétaro"
    description="Frontend, UI/UX, diseño de producto y desarrollo web moderno. Explora la intersección entre código y diseño en GDG Querétaro."
>
    <section class="club-landing container" style="--brand-primary: #34A853;">
        <span
            class="club-landing__badge"
            style="background: rgba(52,168,83,0.15); color: #34A853;"
        >
            Creatividad
        </span>
        <h1 class="club-landing__title">Código y Diseño</h1>
        <p class="club-landing__desc">
            Frontend, UI/UX, diseño de producto y desarrollo web moderno.
            Explora la intersección entre código y diseño con talleres prácticos
            y proyectos colaborativos.
        </p>
        <div class="club-landing__actions">
            <a
                href="/design-code/wiki"
                class="btn-outline"
                style="padding: 0.75rem 2rem;">Contribuye</a
            >
            <a
                href="https://gdg.community.dev/gdg-queretaro/"
                class="btn-primary"
                style="padding: 0.75rem 2rem;">Sesiones →</a
            >
        </div>
    </section>
</GDGLayout>
