---
import GDGLayout from "../../layouts/GDGLayout.astro";
---

<GDGLayout
    title="Mujeres x Diversidad — GDG Querétaro"
    description="Un espacio seguro para mujeres y personas de diversidades en tecnología. Mentoría, talleres y comunidad en GDG Querétaro."
>
    <section class="club-landing container">
        <span
            class="club-landing__badge"
            style="background: rgba(234,67,53,0.15); color: #EA4335;"
        >
            Mujeres x Diversidad
        </span>
        <h1 class="club-landing__title">Mujeres x Diversidad</h1>
        <p class="club-landing__desc">
            Un espacio seguro para mujeres y personas de diversidades en
            tecnología. Mentoría, talleres, conferencias y networking para
            impulsar tu carrera tech.
        </p>
        <div class="club-landing__actions">
            <a
                href="/empowerment/wiki"
                class="btn-primary"
                style="padding: 0.75rem 2rem;">Ver Wiki →</a
            >
            <a
                href="https://gdg.community.dev/gdg-queretaro/"
                class="btn-outline"
                target="_blank"
                rel="noopener"
                style="padding: 0.75rem 2rem;">Únete al club →</a
            >
        </div>
    </section>
</GDGLayout>
