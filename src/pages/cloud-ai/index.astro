---
import GDGLayout from "../../layouts/GDGLayout.astro";
---

<GDGLayout
    title="AI & Cloud — GDG Querétaro"
    description="Explora inteligencia artificial, machine learning, y servicios en la nube de Google con el club AI & Cloud de GDG Querétaro."
>
    <section class="club-landing container">
        <span
            class="club-landing__badge"
            style="background: rgba(66,133,244,0.15); color: #4285F4;"
        >
            AI & Cloud
        </span>
        <h1 class="club-landing__title">AI & Cloud</h1>
        <p class="club-landing__desc">
            Explora inteligencia artificial, machine learning, y servicios en la
            nube de Google. Desde Vertex AI hasta Cloud Run, aprende a construir
            soluciones escalables con tecnología de vanguardia.
        </p>
        <div class="club-landing__actions">
            <a
                href="/cloud-ai/wiki"
                class="btn-primary"
                style="padding: 0.75rem 2rem;">Ver Wiki →</a
            >
            <a
                href="https://gdg.community.dev/gdg-queretaro/"
                class="btn-outline"
                target="_blank"
                rel="noopener"
                style="padding: 0.75rem 2rem;">Únete al club →</a
            >
        </div>
    </section>
</GDGLayout>
