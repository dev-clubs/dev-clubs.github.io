---
import GDGLayout from "../../layouts/GDGLayout.astro";
---

<GDGLayout
    title="Computer Science — GDG Querétaro"
    description="Fundamentos de ciencias de la computación, algoritmos, estructuras de datos y preparación para entrevistas técnicas en GDG Querétaro."
>
    <section class="club-landing container">
        <span
            class="club-landing__badge"
            style="background: rgba(249,171,0,0.15); color: #F9AB00;"
        >
            Computer Science
        </span>
        <h1 class="club-landing__title">Computer Science</h1>
        <p class="club-landing__desc">
            Fundamentos de ciencias de la computación, algoritmos, estructuras
            de datos y preparación para entrevistas técnicas. Aprende los
            building blocks de la ingeniería de software.
        </p>
        <div class="club-landing__actions">
            <a
                href="/computer-science/wiki"
                class="btn-primary"
                style="padding: 0.75rem 2rem;">Ver Wiki →</a
            >
            <a
                href="https://gdg.community.dev/gdg-queretaro/"
                class="btn-outline"
                target="_blank"
                rel="noopener"
                style="padding: 0.75rem 2rem;">Únete al club →</a
            >
        </div>
    </section>
</GDGLayout>
